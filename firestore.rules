rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions

    function authEmail() {
      return request.auth.token.get('email', '');
    }

    function isStudentRole() {
      return userRole() == 'student';
    }

    function isStaffRole() {
      return userRole() == 'staff' || userRole() == 'lecturer';
    }

    function isAdminRole() {
      return userRole() == 'admin' || userRole() == 'super_admin';
    }

    function isPrivilegedPublisher() {
      return isStaffRole() || isAdminRole();
    }

    function touchesModerationFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'moderation_status',
        'is_archived',
        'status',
        'trust_score',
        'suspicion_score'
      ]);
    }

    // Same as hasAllowedDomainForRole but uses a role value passed as
    // an argument instead of reading from the (possibly missing) user doc.
    // Used for the users/create rule where the document doesn't exist yet.
    function domainMatchesRole(role) {
      return (role == 'student'   && authEmail().matches('.*@std\\.must\\.ac\\.ug'))
          || (role in ['lecturer', 'staff'] && authEmail().matches('.*@staff\\.must\\.ac\\.ug'))
          || (role in ['admin', 'super_admin'] && authEmail().matches('.*@must\\.ac\\.ug'));
    }

    function hasAllowedDomainForRole() {
      return (isStudentRole() && authEmail().matches('.*@std\\.must\\.ac\\.ug'))
        || (isStaffRole() && authEmail().matches('.*@staff\\.must\\.ac\\.ug'))
        || (isAdminRole() && authEmail().matches('.*@must\\.ac\\.ug'));
    }

    function isMustUser() {
      return request.auth != null && (hasAllowedDomainForRole() || isRegisteredMustUser());
    }

    // Fallback for users whose email domain doesn't perfectly match their role
    // (e.g. test accounts, newly registered users whose Firestore doc was
    // just created). Accepts any authenticated user who has a valid profile
    // document with a recognized role.
    function isRegisteredMustUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(uid()))
        && get(/databases/$(database)/documents/users/$(uid())).data.get('role', '')
           in ['student', 'lecturer', 'staff', 'admin', 'super_admin'];
    }

    function uid() {
      return request.auth.uid;
    }

    function userRole() {
      // Safe against missing user document — returns '' instead of throwing.
      return exists(/databases/$(database)/documents/users/$(uid()))
        ? get(/databases/$(database)/documents/users/$(uid())).data.get('role', '')
        : '';
    }

    function isAdmin() {
      return isMustUser() && (userRole() == 'admin' || userRole() == 'super_admin');
    }

    function isSuperAdmin() {
      return isMustUser() && userRole() == 'super_admin';
    }


    // USERS
    match /users/{userId} {

      // User profiles are publicly readable — name, avatar, faculty, and role
      // are shown on feed cards and project detail pages for all visitors.
      // The tokens sub-collection (FCM tokens) is separately guarded below.
      allow read: if true;

      // CREATE: the user document does not exist yet, so we cannot call
      // userRole() (which does a get() on the same doc — circular).  
      // Instead, validate the role from the incoming data and match it
      // against the authenticated email domain directly.
      allow create: if request.auth != null
        && userId == uid()
        && request.resource.data.role in ['student', 'lecturer', 'staff', 'admin', 'super_admin']
        && domainMatchesRole(request.resource.data.role);

      allow update: if isMustUser()
        && (userId == uid() || isAdmin());

      allow delete: if isAdmin();

      match /tokens/{tokenId} {
        // Avoid calling isMustUser() here — it invokes userRole() which does a
        // get() on the parent user doc. That doc may not exist yet when the FCM
        // token is first saved (race condition on sign-in), causing permission-
        // denied. Checking request.auth + ownership is sufficient security.
        allow read, write: if request.auth != null && userId == uid();
      }
    }


    // POSTS
    match /posts/{postId} {

      // Non-archived posts are publicly readable so guests see the feed
      // immediately (TikTok-style open discovery).
      // Anonymous visitors are further limited to approved / unmoderated
      // posts so flagged content is never served to unauthenticated clients.
      allow read: if isAdmin()
        || (
          resource.data.is_archived == false
          && (
            isAdmin()
            || resource.data.get('moderation_status', null) in [null, 'approved']
          )
        );

      allow create: if isMustUser()
        && request.resource.data.author_id == uid()
        && request.resource.data.get('is_archived', false) == false
        && (
          (
            isStudentRole()
            && request.resource.data.get('moderation_status', 'pending') == 'pending'
          )
          || (
            isPrivilegedPublisher()
            && request.resource.data.get('moderation_status', 'approved') in ['approved', 'pending']
          )
        );

      allow update: if isMustUser()
        && (
          isAdmin()
          || (
            resource.data.author_id == uid()
            && request.resource.data.author_id == resource.data.author_id
            && !touchesModerationFields()
          )
        );

      allow delete: if isMustUser()
        && (resource.data.author_id == uid() || isAdmin());


      match /likes/{likerId} {
        allow read: if true;  // public like counts
        allow write: if isMustUser() && likerId == uid();
      }

      match /dislikes/{dislikerId} {
        allow read: if true;  // public dislike counts
        allow write: if isMustUser() && dislikerId == uid();
      }
    }


    // CONVERSATIONS
    match /conversations/{convoId} {

      allow read: if isMustUser()
        && (resource.data.user_id == uid()
         || resource.data.peer_id == uid());

      allow create: if isMustUser()
        && request.resource.data.user_id == uid();

      allow update: if isMustUser()
        && (resource.data.user_id == uid()
         || resource.data.peer_id == uid());

      allow delete: if isMustUser()
        && resource.data.user_id == uid();


      match /messages/{msgId} {

        allow read: if isMustUser()
          && (
            get(/databases/$(database)/documents/conversations/$(convoId)).data.user_id == uid()
            || get(/databases/$(database)/documents/conversations/$(convoId)).data.peer_id == uid()
          );

        allow create: if isMustUser()
          && request.resource.data.sender_id == uid();

        allow update: if isMustUser()
          && (
            get(/databases/$(database)/documents/conversations/$(convoId)).data.user_id == uid()
            || get(/databases/$(database)/documents/conversations/$(convoId)).data.peer_id == uid()
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);

        allow delete: if isMustUser()
          && (
            resource.data.sender_id == uid()
            || get(/databases/$(database)/documents/conversations/$(convoId)).data.user_id == uid()
            || isAdmin()
          );
      }
    }


    // NOTIFICATIONS
    match /notifications/{notifId} {

      allow read: if isMustUser() && (resource.data.user_id == uid() || isAdmin());

      // Any authenticated user may create a notification for another user
      // as long as they are the declared sender (prevents impersonation).
      allow create: if isMustUser()
        && request.resource.data.sender_id == uid();

      allow update: if isMustUser()
        && (
          (
            resource.data.user_id == uid()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['is_read', 'extra'])
          )
          || (
            resource.data.sender_id == uid()
            && request.resource.data.sender_id == uid()
            && request.resource.data.user_id == resource.data.user_id
            && request.resource.data.type == resource.data.type
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'sender_name',
              'body',
              'detail',
              'entity_id',
              'is_read',
              'created_at'
            ])
          )
        );

      allow delete: if isMustUser() && resource.data.user_id == uid();
    }


    // FOLLOWS
    match /follows/{followId} {

      allow read: if isMustUser();

      // create AND update needed: FirestoreService.follow() uses .set() which
      // fires an 'update' permission check when the document already exists
      // (e.g. sync retries after a partial write).
      allow create, update: if isMustUser()
        && request.resource.data.follower_id == uid();

      allow delete: if isMustUser()
        && resource.data.follower_id == uid();
    }


    // COLLAB REQUESTS
    match /collab_requests/{requestId} {

      // Sender and receiver can read their own requests.
      allow read: if isMustUser()
        && (resource.data.sender_id == uid()
         || resource.data.receiver_id == uid()
         || isAdmin());

      // Only the sender can create a request (and set/retry via sync).
      allow create, update: if isMustUser()
        && request.resource.data.sender_id == uid();

      // Receiver can update only the status field (accept/decline).
      allow update: if isMustUser()
        && resource.data.receiver_id == uid()
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'updated_at', 'responded_at']);

      allow delete: if isMustUser()
        && resource.data.sender_id == uid();
    }


    // OPPORTUNITY JOINS
    match /post_joins/{joinId} {

      allow read: if isMustUser()
        && (
          resource.data.user_id == uid()
          || resource.data.author_id == uid()
          || isAdmin()
        );

      allow create, update: if isMustUser()
        && request.resource.data.user_id == uid();

      allow delete: if isMustUser()
        && (resource.data.user_id == uid() || isAdmin());
    }


    // MODERATION REPORTS
    match /moderation_queue/{reportId} {

      allow read: if isMustUser()
        && (resource.data.reporter_id == uid() || isAdmin());

      allow create, update: if isMustUser()
        && request.resource.data.reporter_id == uid();

      allow delete: if isAdmin();
    }


    // COMMENTS
    match /comments/{commentId} {

      allow read: if isMustUser();

      allow create, update: if isMustUser()
        && request.resource.data.author_id == uid();

      allow delete: if isMustUser()
        && (resource.data.author_id == uid() || isAdmin());
    }


    // UNIQUE POST VIEWS
    match /post_views/{viewId} {

      allow read: if isMustUser()
        && (
          resource.data.viewer_id == uid()
          || resource.data.author_id == uid()
          || isAdmin()
        );

      allow create: if isMustUser()
        && request.resource.data.viewer_id == uid();

      // update: viewer_id is not re-sent on partial .update() calls, so check
      // the *existing* document's viewer_id against the caller instead.
      allow update: if isMustUser()
        && resource.data.viewer_id == uid();

      allow delete: if isAdmin();
    }


    // POST RATINGS
    match /post_ratings/{ratingId} {

      allow read: if isMustUser()
        && (resource.data.user_id == uid() || isAdmin());

      allow create, update: if isMustUser()
        && request.resource.data.user_id == uid();

      allow delete: if isMustUser()
        && (resource.data.user_id == uid() || isAdmin());
    }


    // RECOMMENDATION LOGS
    match /recommendation_logs/{logId} {

      allow read: if request.auth != null
        && (resource.data.user_id == request.auth.uid || isAdmin());

      // Analytics writes: only require auth + ownership.
      // Omitting isMustUser() here avoids userRole() get() failures
      // that would block logging when the Firestore user doc is briefly
      // unavailable during a first-launch or offline hydration cycle.
      allow create, update: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;

      allow delete: if isAdmin();
    }


    // GROUPS
    match /groups/{groupId} {

      allow read: if isMustUser();

      allow create: if isMustUser()
        && request.resource.data.creator_id == uid();

      allow update: if isMustUser()
        && (resource.data.creator_id == uid() || isAdmin());

      allow delete: if isAdmin();
    }


    // GROUP MEMBERS
    match /group_members/{membershipId} {

      allow read: if isMustUser();

      allow create: if isMustUser()
        && (
          request.resource.data.invited_by == uid()
          || get(/databases/$(database)/documents/groups/$(request.resource.data.group_id)).data.creator_id == uid()
          || isAdmin()
        );

      allow update: if isMustUser()
        && (
          resource.data.user_id == uid()
          || resource.data.invited_by == uid()
          || get(/databases/$(database)/documents/groups/$(resource.data.group_id)).data.creator_id == uid()
          || isAdmin()
        );

      allow delete: if isMustUser()
        && (
          resource.data.user_id == uid()
          || resource.data.invited_by == uid()
          || get(/databases/$(database)/documents/groups/$(resource.data.group_id)).data.creator_id == uid()
          || isAdmin()
        );
    }


    // APP FEEDBACK
    match /app_feedback/{feedbackId} {

      allow read: if isMustUser();

      allow create, update: if isMustUser()
        && request.resource.data.user_id == uid();

      allow delete: if isMustUser()
        && (resource.data.user_id == uid() || isAdmin());
    }


    // CHATBOT INTERACTIONS
    match /chatbot_interactions/{interactionId} {

      // Admins can inspect chatbot traces for accuracy benchmarking.
      // Owners can read their own traces.
      allow read: if isAdmin()
        || (isMustUser() && resource.data.user_id == uid());

      // Signed-in users can create/update traces generated by their own session.
      allow create, update: if isMustUser()
        && request.resource.data.user_id == uid();

      allow delete: if isAdmin();
    }


    // ACCOUNT DELETION REQUESTS
    match /account_deletion_requests/{requestId} {

      // Request owner and admins can read the record.
      allow read: if isAdmin()
        || (isMustUser() && resource.data.user_id == uid());

      // User can create their own deletion request and keep it pending.
      allow create: if isMustUser()
        && request.resource.data.user_id == uid()
        && request.resource.data.status == 'pending';

      // Only admins can update review state.
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }


    // AUDIT LOG
    match /audit_log/{logId} {

      allow read: if isSuperAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }


    // SKILLS
    match /skills/{skillId} {

      allow read: if isMustUser();
      allow write: if isAdmin();
    }


    // FACULTIES
    match /faculties/{facultyId} {

      // Public read — all users can see faculty listings
      allow read: if true;

      // Admins can create, update, archive faculties
      allow create, update: if isAdmin();

      // Admins can soft-delete (via archive) — hard deletes forbidden
      allow delete: if false;
    }


    // COURSES
    match /courses/{courseId} {

      // Public read — all users can see course listings
      allow read: if true;

      // Admins can create, update, archive courses
      allow create, update: if isAdmin();

      // Admins can soft-delete (via archive) — hard deletes forbidden
      allow delete: if false;
    }


    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

  }
}