rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions

    function authEmail() {
      return request.auth.token.get('email', '');
    }

    function isStudentRole() {
      return userRole() == 'student';
    }

    function isStaffRole() {
      return userRole() == 'staff' || userRole() == 'lecturer';
    }

    function isAdminRole() {
      return userRole() == 'admin' || userRole() == 'super_admin';
    }

    // Same as hasAllowedDomainForRole but uses a role value passed as
    // an argument instead of reading from the (possibly missing) user doc.
    // Used for the users/create rule where the document doesn't exist yet.
    function domainMatchesRole(role) {
      return (role == 'student'   && authEmail().matches('.*@std\\.must\\.ac\\.ug'))
          || (role in ['lecturer', 'staff'] && authEmail().matches('.*@staff\\.must\\.ac\\.ug'))
          || (role in ['admin', 'super_admin'] && authEmail().matches('.*@must\\.ac\\.ug'));
    }

    function hasAllowedDomainForRole() {
      return (isStudentRole() && authEmail().matches('.*@std\\.must\\.ac\\.ug'))
        || (isStaffRole() && authEmail().matches('.*@staff\\.must\\.ac\\.ug'))
        || (isAdminRole() && authEmail().matches('.*@must\\.ac\\.ug'));
    }

    function isMustUser() {
      return request.auth != null && hasAllowedDomainForRole();
    }

    function uid() {
      return request.auth.uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    function isAdmin() {
      return isMustUser() && (userRole() == 'admin' || userRole() == 'super_admin');
    }

    function isSuperAdmin() {
      return isMustUser() && userRole() == 'super_admin';
    }


    // USERS
    match /users/{userId} {

      // User profiles are publicly readable — name, avatar, faculty, and role
      // are shown on feed cards and project detail pages for all visitors.
      // The tokens sub-collection (FCM tokens) is separately guarded below.
      allow read: if true;

      // CREATE: the user document does not exist yet, so we cannot call
      // userRole() (which does a get() on the same doc — circular).  
      // Instead, validate the role from the incoming data and match it
      // against the authenticated email domain directly.
      allow create: if request.auth != null
        && userId == uid()
        && request.resource.data.role in ['student', 'lecturer', 'staff', 'admin', 'super_admin']
        && domainMatchesRole(request.resource.data.role);

      allow update: if isMustUser()
        && (userId == uid() || isAdmin());

      allow delete: if isAdmin();

      match /tokens/{tokenId} {
        allow read, write: if isMustUser() && userId == uid();
      }
    }


    // POSTS
    match /posts/{postId} {

      // Non-archived posts are publicly readable so guests see the feed
      // immediately (TikTok-style open discovery).
      // Anonymous visitors are further limited to approved / unmoderated
      // posts so flagged content is never served to unauthenticated clients.
      allow read: if resource.data.is_archived == false
        && (request.auth != null
            || resource.data.get('moderation_status', null) in [null, 'approved']);

      allow create: if isMustUser()
        && request.resource.data.author_id == uid();

      allow update: if isMustUser()
        && (resource.data.author_id == uid() || isAdmin());

      allow delete: if isMustUser()
        && (resource.data.author_id == uid() || isAdmin());


      match /likes/{likerId} {
        allow read: if true;  // public like counts
        allow write: if isMustUser() && likerId == uid();
      }

      match /dislikes/{dislikerId} {
        allow read: if true;  // public dislike counts
        allow write: if isMustUser() && dislikerId == uid();
      }
    }


    // CONVERSATIONS
    match /conversations/{convoId} {

      allow read: if isMustUser()
        && (resource.data.user_id == uid()
         || resource.data.peer_id == uid());

      allow create: if isMustUser()
        && request.resource.data.user_id == uid();

      allow update: if isMustUser()
        && (resource.data.user_id == uid()
         || resource.data.peer_id == uid());

      allow delete: if isMustUser()
        && resource.data.user_id == uid();


      match /messages/{msgId} {

        allow read: if isMustUser()
          && (
            get(/databases/$(database)/documents/conversations/$(convoId)).data.user_id == uid()
            || get(/databases/$(database)/documents/conversations/$(convoId)).data.peer_id == uid()
          );

        allow create: if isMustUser()
          && request.resource.data.sender_id == uid();

        allow update: if isMustUser()
          && (
            get(/databases/$(database)/documents/conversations/$(convoId)).data.user_id == uid()
            || get(/databases/$(database)/documents/conversations/$(convoId)).data.peer_id == uid()
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);

        allow delete: if isMustUser()
          && (
            resource.data.sender_id == uid()
            || get(/databases/$(database)/documents/conversations/$(convoId)).data.user_id == uid()
            || isAdmin()
          );
      }
    }


    // NOTIFICATIONS
    match /notifications/{notifId} {

      allow read: if isMustUser() && resource.data.user_id == uid();

      // Any authenticated user may create a notification for another user
      // as long as they are the declared sender (prevents impersonation).
      allow create: if isMustUser()
        && request.resource.data.sender_id == uid();

      allow update: if isMustUser()
        && (
          (
            resource.data.user_id == uid()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['is_read', 'extra'])
          )
          || (
            resource.data.sender_id == uid()
            && request.resource.data.sender_id == uid()
            && request.resource.data.user_id == resource.data.user_id
            && request.resource.data.type == resource.data.type
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'sender_name',
              'body',
              'detail',
              'entity_id',
              'is_read',
              'created_at'
            ])
          )
        );

      allow delete: if isMustUser() && resource.data.user_id == uid();
    }


    // FOLLOWS
    match /follows/{followId} {

      allow read: if isMustUser();

      // create AND update needed: FirestoreService.follow() uses .set() which
      // fires an 'update' permission check when the document already exists
      // (e.g. sync retries after a partial write).
      allow create, update: if isMustUser()
        && request.resource.data.follower_id == uid();

      allow delete: if isMustUser()
        && resource.data.follower_id == uid();
    }


    // COLLAB REQUESTS
    match /collab_requests/{requestId} {

      // Sender and receiver can read their own requests.
      allow read: if isMustUser()
        && (resource.data.sender_id == uid()
         || resource.data.receiver_id == uid());

      // Only the sender can create a request (and set/retry via sync).
      allow create, update: if isMustUser()
        && request.resource.data.sender_id == uid();

      // Receiver can update only the status field (accept/decline).
      allow update: if isMustUser()
        && resource.data.receiver_id == uid()
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'updated_at', 'responded_at']);

      allow delete: if isMustUser()
        && resource.data.sender_id == uid();
    }


    // OPPORTUNITY JOINS
    match /post_joins/{joinId} {

      allow read: if isMustUser()
        && (
          resource.data.user_id == uid()
          || resource.data.author_id == uid()
          || isAdmin()
        );

      allow create, update: if isMustUser()
        && request.resource.data.user_id == uid();

      allow delete: if isMustUser()
        && (resource.data.user_id == uid() || isAdmin());
    }


    // MODERATION REPORTS
    match /moderation_queue/{reportId} {

      allow read: if isMustUser()
        && (resource.data.reporter_id == uid() || isAdmin());

      allow create, update: if isMustUser()
        && request.resource.data.reporter_id == uid();

      allow delete: if isAdmin();
    }


    // COMMENTS
    match /comments/{commentId} {

      allow read: if isMustUser();

      allow create, update: if isMustUser()
        && request.resource.data.author_id == uid();

      allow delete: if isMustUser()
        && (resource.data.author_id == uid() || isAdmin());
    }


    // UNIQUE POST VIEWS
    match /post_views/{viewId} {

      allow read: if isMustUser()
        && (
          resource.data.viewer_id == uid()
          || resource.data.author_id == uid()
          || isAdmin()
        );

      allow create, update: if isMustUser()
        && request.resource.data.viewer_id == uid();

      allow delete: if isAdmin();
    }


    // AUDIT LOG
    match /audit_log/{logId} {

      allow read: if isSuperAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }


    // SKILLS
    match /skills/{skillId} {

      allow read: if isMustUser();
      allow write: if isAdmin();
    }


    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

  }
}