foreach ($f in $files) {
  New-Item -ItemType Directory -Force -Path (Split-Path $f.Path) | Out-Null
  $sectionsCode = ($f.Sections | ForEach-Object { "      '$_'," }) -join "`n"
  $content = @"
import 'package:flutter/material.dart';

import '../../shared/widgets/feature_placeholder_screen.dart';

class $($f.Class) extends StatelessWidget {
  const $($f.Class)({super.key});

  @override
  Widget build(BuildContext context) {
    return const FeaturePlaceholderScreen(
      title: '$($f.Title)',
      subtitle: '$($f.Subtitle)',
      sections: [
$sectionsCode
      ],
    );
  }
}
"@
  if ($f.Path -like 'lib/features/admin/*' -or $f.Path -like 'lib/features/super_admin/*') {
    $content = $content.Replace("import '../../shared/widgets/feature_placeholder_screen.dart';", "import '../../shared/widgets/feature_placeholder_screen.dart';")
  }
  Set-Content -Path $f.Path -Value $content -Encoding UTF8
}

